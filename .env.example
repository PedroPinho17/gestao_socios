APP_NAME="Gestão de Sócios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Frontend React (área do sócio)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Base de dados (obrigatório) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gestao_socios
DB_USERNAME=root
DB_PASSWORD=

# --- Produção (cPanel) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app.seuclube.pt

# --- Opcional (Laravel usa defaults em config/ se omitir) ---
# APP_LOCALE=pt
# SESSION_DRIVER=file
# CACHE_STORE=file
# QUEUE_CONNECTION=sync
# BCRYPT_ROUNDS=4   # só local; produção use 12

# Clube, 2FA, quotas, utilizadores → base de dados / painel admin (não .env)

# --- Email (comprovativos de pagamento) ---
# Em dev, MAIL_MAILER=log escreve os emails em storage/logs/laravel.log.
# Em produção, configure o SMTP do clube para enviar emails reais:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.seuclube.pt
# MAIL_PORT=587
# MAIL_USERNAME=geral@seuclube.pt
# MAIL_PASSWORD=
# MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="geral@seuclube.pt"
MAIL_FROM_NAME="${APP_NAME}"

# --- Logótipo do backend (painel, login, validação QR, área do sócio) ---
# Caminho relativo a public/ — o cartão usa upload em Definições do clube.
CLUB_LOGO=img/vale_logo.png

# Textos opcionais da área do sócio (ver também config/club.php)
# CLUB_MEMBER_AREA_TITLE="Área do sócio"
# CLUB_MEMBER_AREA_LOGIN_SUBTITLE="Inicie sessão com o email e password do clube."

# --- Export cartão (Browsershot — PDF/PNG profissional, opcional) ---
# Requer Node.js + Google Chrome. Sem isto: fallback DomPDF (PDF) e GD (PNG).
# BROWSERSHOT_CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# BROWSERSHOT_NODE_BINARY="C:\Program Files\nodejs\node.exe"
# BROWSERSHOT_NPM_BINARY="C:\Program Files\nodejs\npm.cmd"
# BROWSERSHOT_NO_SANDBOX=false
