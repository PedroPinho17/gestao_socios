APP_NAME="Gestão de Sócios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Base de dados (obrigatório) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gestao_socios
DB_USERNAME=root
DB_PASSWORD=

# --- Produção (cPanel) ---
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app.seuclube.pt

# --- Opcional (Laravel usa defaults em config/ se omitir) ---
# APP_LOCALE=pt
# SESSION_DRIVER=file
# CACHE_STORE=file
# QUEUE_CONNECTION=sync
# BCRYPT_ROUNDS=4   # só local; produção use 12

# Clube, 2FA, quotas, utilizadores → base de dados / painel admin (não .env)

# --- Logótipo do backend (painel, login, validação QR) ---
# Caminho relativo a public/ — o cartão usa upload em Definições do clube.
CLUB_LOGO=img/vale_logo.png

# --- Export cartão (Browsershot — PDF/PNG profissional, opcional) ---
# Requer Node.js + Google Chrome. Sem isto: fallback DomPDF (PDF) e GD (PNG).
# BROWSERSHOT_CHROME_PATH="C:\Program Files\Google\Chrome\Application\chrome.exe"
# BROWSERSHOT_NODE_BINARY="C:\Program Files\nodejs\node.exe"
# BROWSERSHOT_NPM_BINARY="C:\Program Files\nodejs\npm.cmd"
# BROWSERSHOT_NO_SANDBOX=false
