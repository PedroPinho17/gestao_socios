APP_NAME="Gestão de Sócios"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# --- Base de dados (obrigatório) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gestao_socios
DB_USERNAME=root
DB_PASSWORD=

